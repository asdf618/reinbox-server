{
  "port": 16861,
  "root_dir": "/path/to/your/projects",
  "db_path": "/path/to/your/reinbox.db",
  "base_path": "",
  "bind": [],
  "private_key_file": "",
  "open_server": true,
  "allowed_clients": [],
  "agents": [
    {
      "type": "claude",
      "name": "Claude",
      "scope": "workspace",
      "path": "/usr/local/bin/claude",
      "models": [
        "sonnet",
        "opus",
        "haiku"
      ],
      "efforts": [
        "low",
        "medium",
        "high",
        "xhigh",
        "max"
      ],
      "args": [
        "--permission-mode",
        "bypassPermissions"
      ],
      "home_dir": ""
    },
    {
      "type": "codex",
      "name": "Codex",
      "scope": "workspace",
      "path": "/usr/local/bin/codex",
      "models": [
        "gpt-5.5",
        "gpt-5.4-mini"
      ],
      "efforts": [
        "minimal",
        "low",
        "medium",
        "high",
        "xhigh"
      ],
      "args": [
        "--dangerously-bypass-approvals-and-sandbox"
      ],
      "home_dir": ""
    }
  ]
}